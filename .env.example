BIND_ADDR=127.0.0.1:20443

DATABASE_URL=postgres://kradra:kradra_local_password@127.0.0.1:5432/kradra

JWT_SECRET=change_me_dev_secret
ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=30

COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
COOKIE_DOMAIN=

AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_BODY_LIMIT_BYTES=8192
AUTH_RATE_LIMIT_KEY_MODE=ip_username
AUTH_RATE_LIMIT_ENTRY_TTL_SECONDS=600
AUTH_RATE_LIMIT_CLEANUP_EVERY_N=200

AUTH_SLOWDOWN_ENABLED=true
AUTH_SLOWDOWN_START_AFTER=3
AUTH_SLOWDOWN_STEP_MS=200
AUTH_SLOWDOWN_MAX_DELAY_MS=2000
AUTH_SLOWDOWN_WINDOW_SECONDS=900
AUTH_SLOWDOWN_ENTRY_TTL_SECONDS=3600
AUTH_SLOWDOWN_CLEANUP_EVERY_N=200

AUTH_LOCKOUT_MAX_FAILURES=10
AUTH_LOCKOUT_SECONDS=900
